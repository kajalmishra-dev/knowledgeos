# =============================================================================
# KnowledgeOS - Local Development Environment (Docker Compose)
# Copy this file to `.env` in the repository root before running:
#   docker compose up --build
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL 17 (pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledgeos
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis 8
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=knowledgeos
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000

APP_NAME=KnowledgeOS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Docker-internal service hostnames (used by the backend container)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/knowledgeos
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
