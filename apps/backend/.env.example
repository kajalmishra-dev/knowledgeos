# =============================================================================
# KnowledgeOS Backend - Environment Variables
# =============================================================================

# Application
APP_NAME=KnowledgeOS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Local development (backend run directly on host)
# Start infrastructure first: docker compose up postgres redis minio -d
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/knowledgeos
DATABASE_ECHO=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledgeos
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# Docker Compose (backend run inside container)
# Use root `.env` — these values are injected automatically by docker-compose.yml
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/knowledgeos
# REDIS_URL=redis://redis:6379/0
# MINIO_ENDPOINT=minio:9000
